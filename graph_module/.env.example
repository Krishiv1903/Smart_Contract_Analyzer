# ==========================================================
# Legal Knowledge Graph
# Environment Configuration
# ==========================================================

# ----------------------------------------------------------
# General
# ----------------------------------------------------------

APP_NAME=LegalKnowledgeGraph
APP_VERSION=1.0.0
DEBUG=True

# ----------------------------------------------------------
# Logging
# ----------------------------------------------------------

LOG_LEVEL=INFO

# Options:
# DEBUG
# INFO
# WARNING
# ERROR
# CRITICAL

# ----------------------------------------------------------
# LLM Configuration
# ----------------------------------------------------------

# Provider
# Options:
# groq
# ollama

LLM_PROVIDER=groq

# ----------------------------------------------------------
# Groq
# ----------------------------------------------------------

GROQ_API_KEY=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

GROQ_MODEL=llama-3.3-70b-versatile

# ----------------------------------------------------------
# Ollama
# ----------------------------------------------------------

OLLAMA_MODEL=llama3.1:8b

OLLAMA_HOST=http://localhost:11434

# ----------------------------------------------------------
# spaCy
# ----------------------------------------------------------

SPACY_MODEL=en_core_web_sm

# ----------------------------------------------------------
# Graph Visualization
# ----------------------------------------------------------

GRAPH_LAYOUT=spring

GRAPH_PHYSICS=True

GRAPH_NODE_SIZE=20

GRAPH_EDGE_WIDTH=2

# ----------------------------------------------------------
# Output Directories
# ----------------------------------------------------------

INPUT_DIR=input

OUTPUT_DIR=output

JSON_OUTPUT_DIR=output/json

HTML_OUTPUT_DIR=output/html

GRAPH_OUTPUT_DIR=output/graphs

LOG_DIR=logs

PROMPT_DIR=prompts

# ----------------------------------------------------------
# Cache
# ----------------------------------------------------------

ENABLE_CACHE=True

CACHE_DIR=.cache

# ----------------------------------------------------------
# LLM Parameters
# ----------------------------------------------------------

TEMPERATURE=0.1

MAX_TOKENS=4096

TOP_P=0.95

REQUEST_TIMEOUT=120

MAX_RETRIES=3

# ----------------------------------------------------------
# Dependency Detection
# ----------------------------------------------------------

SIMILARITY_THRESHOLD=0.65

USE_RULE_BASED_DEPENDENCY=True

USE_LLM_DEPENDENCY=True

# ----------------------------------------------------------
# Extraction
# ----------------------------------------------------------

USE_REGEX=True

USE_SPACY=True

USE_LLM=True

ENTITY_CONFIDENCE_THRESHOLD=0.70

RELATION_CONFIDENCE_THRESHOLD=0.70

DEPENDENCY_CONFIDENCE_THRESHOLD=0.75

# ----------------------------------------------------------
# Export
# ----------------------------------------------------------

EXPORT_JSON=True

EXPORT_GRAPHML=True

EXPORT_GEXF=True

EXPORT_HTML=True

EXPORT_PNG=True

# ----------------------------------------------------------
# Versioning
# ----------------------------------------------------------

GRAPH_SCHEMA_VERSION=1.0