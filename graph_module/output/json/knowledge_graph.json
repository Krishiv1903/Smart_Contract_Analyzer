        {
            "id": "C1",
            "label": "Acceptance",
            "type": "CLAUSE",
            "source_id": "C1",
            "clause_id": "C1",
            "metadata": {
                "text": "By creating an account, the user agrees to these Terms and Conditions."
            }
        },
        {
            "id": "C2",
            "label": "Account",
            "type": "CLAUSE",
            "source_id": "C2",
            "clause_id": "C2",
            "metadata": {
                "text": "The user must provide accurate information while creating an account."
            }
        },
        {
            "id": "C3",
            "label": "Payments",
            "type": "CLAUSE",
            "source_id": "C3",
            "clause_id": "C3",
            "metadata": {
                "text": "Subscription fees must be paid within 30 days of receiving the invoice."
            }
        },
        {
            "id": "C4",
            "label": "Refund",
            "type": "CLAUSE",
            "source_id": "C4",
            "clause_id": "C4",
            "metadata": {
                "text": "Refunds are available only under the conditions described in Clause C3."
            }
        },
        {
            "id": "C5",
            "label": "Privacy",
            "type": "CLAUSE",
            "source_id": "C5",
            "clause_id": "C5",
            "metadata": {
                "text": "We collect personal information according to our Privacy Policy."
            }
        },
        {
            "id": "C6",
            "label": "Data Sharing",
            "type": "CLAUSE",
            "source_id": "C6",
            "clause_id": "C6",
            "metadata": {
                "text": "Personal information may be shared with third-party service providers as described in Clause C5."
            }
        },
        {
            "id": "C7",
            "label": "Termination",
            "type": "CLAUSE",
            "source_id": "C7",
            "clause_id": "C7",
            "metadata": {
                "text": "We may terminate your account if you violate these Terms or fail to comply with Clause C2."
            }
        },
        {
            "id": "C8",
            "label": "User Obligations",
            "type": "CLAUSE",
            "source_id": "C8",
            "clause_id": "C8",
            "metadata": {
                "text": "The user shall not misuse the service or attempt unauthorized access."
            }
        },
        {
            "id": "C9",
            "label": "Limitation of Liability",
            "type": "CLAUSE",
            "source_id": "C9",
            "clause_id": "C9",
            "metadata": {
                "text": "Our liability shall not exceed the amount paid by the user during the previous twelve months."
            }
        },
        {
            "id": "C10",
            "label": "Changes",
            "type": "CLAUSE",
            "source_id": "C10",
            "clause_id": "C10",
            "metadata": {
                "text": "We may modify these Terms at any time. Continued use of the service constitutes acceptance of the updated Terms."
            }
        },
