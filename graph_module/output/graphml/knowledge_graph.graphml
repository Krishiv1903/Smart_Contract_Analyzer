</node>
<node id="C9">
  <data key="d0">Limitation of Liability</data>
  <data key="d1">CLAUSE</data>
  <data key="d2">Our liability shall not exceed the amount paid by the user during the previous twelve months.</data>
</node>
<node id="C10">
  <data key="d0">Changes</data>
  <data key="d1">CLAUSE</data>
