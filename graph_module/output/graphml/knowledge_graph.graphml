  <data key="d0">Account</data>
  <data key="d1">CLAUSE</data>
  <data key="d2">The user must provide accurate information while creating an account.</data>
</node>
<node id="C3">
  <data key="d0">Payments</data>
  <data key="d1">CLAUSE</data>
  <data key="d2">Subscription fees must be paid within 30 days of receiving the invoice.</data>
</node>
<node id="C4">
  <data key="d0">Refund</data>
  <data key="d1">CLAUSE</data>
  <data key="d2">Refunds are available only under the conditions described in Clause C3.</data>
</node>
