    <nodes>
      <node id="C1" label="Acceptance">
        <attvalues>
          <attvalue for="0" value="CLAUSE" />
          <attvalue for="1" value="By creating an account, the user agrees to these Terms and Conditions." />
        </attvalues>
      </node>
      <node id="C2" label="Account">
        <attvalues>
          <attvalue for="0" value="CLAUSE" />
          <attvalue for="1" value="The user must provide accurate information while creating an account." />
        </attvalues>
      </node>
      <node id="C3" label="Payments">
        <attvalues>
          <attvalue for="0" value="CLAUSE" />
          <attvalue for="1" value="Subscription fees must be paid within 30 days of receiving the invoice." />
        </attvalues>
      </node>
      <node id="C4" label="Refund">
        <attvalues>
          <attvalue for="0" value="CLAUSE" />
          <attvalue for="1" value="Refunds are available only under the conditions described in Clause C3." />
        </attvalues>
      </node>
      <node id="C5" label="Privacy">
        <attvalues>
          <attvalue for="0" value="CLAUSE" />
          <attvalue for="1" value="We collect personal information according to our Privacy Policy." />
        </attvalues>
      </node>
      <node id="C6" label="Data Sharing">
        <attvalues>
          <attvalue for="0" value="CLAUSE" />
          <attvalue for="1" value="Personal information may be shared with third-party service providers as described in Clause C5." />
        </attvalues>
      </node>
      <node id="C7" label="Termination">
        <attvalues>
          <attvalue for="0" value="CLAUSE" />
          <attvalue for="1" value="We may terminate your account if you violate these Terms or fail to comply with Clause C2." />
        </attvalues>
      </node>
      <node id="C8" label="User Obligations">
        <attvalues>
          <attvalue for="0" value="CLAUSE" />
          <attvalue for="1" value="The user shall not misuse the service or attempt unauthorized access." />
        </attvalues>
      </node>
      <node id="C9" label="Limitation of Liability">
        <attvalues>
          <attvalue for="0" value="CLAUSE" />
          <attvalue for="1" value="Our liability shall not exceed the amount paid by the user during the previous twelve months." />
        </attvalues>
      </node>
      <node id="C10" label="Changes">
        <attvalues>
          <attvalue for="0" value="CLAUSE" />
          <attvalue for="1" value="We may modify these Terms at any time. Continued use of the service constitutes acceptance of the updated Terms." />
        </attvalues>
      </node>
